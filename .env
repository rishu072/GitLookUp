# GitPulse Environment Configurations

# GitHub Personal Access Token (PAT)
# Unauthenticated requests are limited to 60/hr. Generate a token at https://github.com/settings/tokens
# and paste it below to increase limits to 5000/hr.
GITHUB_TOKEN=

# Backend server configurations
PORT=5000
FLASK_ENV=development

# Cache duration (in seconds). Default is 3600 (1 hour).
CACHE_TTL=3600
